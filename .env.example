# LLM Backend: "ollama" (local) or "hf" (HuggingFace Inference API, free)
LLM_BACKEND=ollama
LLM_MODEL=gemma2:9b
OLLAMA_URL=http://localhost:11434

# HuggingFace Inference API (free tier, no key needed for public models)
HF_MODEL=mistralai/Mistral-7B-Instruct-v0.3
HF_API_TOKEN=

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB path
CHROMA_PATH=./data/vectorstore

# SEC EDGAR (required for downloading filings)
SEC_AGENT_NAME=DueDiligenceAI Bot
SEC_AGENT_EMAIL=duediligenceai@proton.me
